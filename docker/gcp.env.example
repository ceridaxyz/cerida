# Copy to docker/.env.gcp and fill these in when you are ready to point
# local tooling at an actual GCP project.
GCP_PROJECT_ID=cerida-dev
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# Optional: used by the cloud-sql-proxy profile.
# Format: project:region:instance
GCP_CLOUD_SQL_INSTANCE=cerida-dev:us-central1:cerida-timescale
