# ── Infrastructure ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cerida
REDIS_URL=redis://localhost:6379
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
PREDICT_BASE=https://predict-server.testnet.mystenlabs.com
POLL_MS=3000

# ── API ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8788

# ── Indexer ────────────────────────────────────────────────────────────────────
# The cerida Move package ID (from `sui client publish`)
CERIDA_PACKAGE_ID=0x...

# ── Keeper Execution ───────────────────────────────────────────────────────────
# Set to false to actually sign and submit transactions
KEEPER_DRY_RUN=true

# Bech32 Sui private key for the keeper wallet (suiprivkey1...)
# Get from: sui keytool export --key-identity <alias>
KEEPER_PRIVATE_KEY=suiprivkey1...

# Gas budget per transaction in MIST (default 50_000_000 = 0.05 SUI)
GAS_BUDGET=50000000

# ── Deployed Object IDs ────────────────────────────────────────────────────────
# From the VaultCreated event emitted when the vault was deployed
VAULT_ID=0x...

# The Predict singleton object ID from DeepBook deployment
PREDICT_OBJECT_ID=0x...

# From PoolCreated event (cerida::leverage)
MARGIN_POOL_ID=0x...

# From create_book call (cerida::leverage)
LEVERAGE_BOOK_ID=0x...

# From cerida::windows WindowBook creation
WINDOW_BOOK_ID=0x...

# ── Coin Type ─────────────────────────────────────────────────────────────────
# The Move type string for the vault's Quote coin.
# Testnet examples:
#   SUI:   0x2::sui::SUI
#   dUSDC: 0x<deepbook_pkg>::dusdc::DUSDC
QUOTE_COIN_TYPE=0x2::sui::SUI
